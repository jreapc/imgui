{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build project",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/MD",
                "/std:c++17",

                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                // Include paths
                "/I", "${workspaceFolder}/tpi",
                "/I", "${workspaceFolder}/tpi/imgui",
                "/I", "${workspaceFolder}/tpi/glfw",
                "/I", "${workspaceFolder}/tpi/backend",
                // Source files to compile
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/tpi/imgui/*.cpp",
                "${workspaceFolder}/tpi/backend/*.cpp",
                // Linker flags and libraries
                "/link",
                "/LIBPATH:${workspaceFolder}/lib",
                "glfw3.lib",
                "opengl32.lib",
                "user32.lib",
                "gdi32.lib",
                "shell32.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}